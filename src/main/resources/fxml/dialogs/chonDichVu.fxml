<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialog.ChonDichVuDialog"
      stylesheets="@../../css/style.css"
      spacing="0" style="-fx-min-width:500;">

    <HBox styleClass="dialog-header" spacing="12" alignment="CENTER_LEFT">
        <Label text="🥤" style="-fx-font-size:22px;"/>
        <VBox spacing="2">
            <Label text="Order Dịch Vụ" styleClass="dialog-title"/>
            <Label fx:id="lblPhienInfo" text="Phiên: ..." style="-fx-text-fill:#90CAF9; -fx-font-size:12px;"/>
        </VBox>
    </HBox>

    <VBox styleClass="dialog-body" spacing="12">
        <!-- Search -->
        <TextField fx:id="txtSearch" promptText="🔍  Tìm dịch vụ..." styleClass="search-bar"
                   onKeyReleased="#handleSearch"/>

        <!-- DV list table -->
        <TableView fx:id="tableDichVu" prefHeight="220">
            <TableColumn fx:id="colMaDV" text="Mã DV" prefWidth="80"/>
            <TableColumn fx:id="colTenDV" text="Tên dịch vụ" prefWidth="200"/>
            <TableColumn fx:id="colGia" text="Đơn giá" prefWidth="100"/>
            <TableColumn fx:id="colTonKho" text="Tồn kho" prefWidth="90"/>
        </TableView>

        <!-- Selected item + quantity -->
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color:#EBF5FB;
              -fx-background-radius:8; -fx-padding:12; -fx-border-color:#BBDEFB;
              -fx-border-width:1; -fx-border-radius:8;">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Dịch vụ đã chọn:" style="-fx-text-fill:#888888; -fx-font-size:12px;"/>
                <Label fx:id="lblSelectedDV" text="Chưa chọn dịch vụ"
                       style="-fx-font-weight:bold; -fx-font-size:13px;"/>
            </VBox>
            <VBox spacing="4" alignment="CENTER">
                <Label text="Số lượng:" styleClass="form-label"/>
                <HBox spacing="4" alignment="CENTER">
                    <Button text="−" styleClass="btn btn-secondary"
                            style="-fx-padding:4 10;" onAction="#handleDecrease"/>
                    <TextField fx:id="txtSoLuong" text="1" styleClass="text-field"
                               prefWidth="60" style="-fx-alignment:CENTER;"/>
                    <Button text="＋" styleClass="btn btn-primary"
                            style="-fx-padding:4 10;" onAction="#handleIncrease"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Cart / order list -->
        <Label text="Giỏ hàng:" style="-fx-font-weight:bold; -fx-text-fill:#555555;"/>
        <TableView fx:id="tableCart" prefHeight="150">
            <TableColumn fx:id="colCartDV" text="Dịch vụ" prefWidth="200"/>
            <TableColumn fx:id="colCartSL" text="SL" prefWidth="50"/>
            <TableColumn fx:id="colCartDonGia" text="Đơn giá" prefWidth="100"/>
            <TableColumn fx:id="colCartThanhTien" text="Thành tiền" prefWidth="110"/>
            <TableColumn fx:id="colCartXoa" text="" prefWidth="50"/>
        </TableView>

        <HBox alignment="CENTER_RIGHT">
            <Label text="Tổng tiền order: " style="-fx-font-weight:bold;"/>
            <Label fx:id="lblTongTienCart" text="0 ₫" styleClass="currency-label"/>
        </HBox>

        <Label fx:id="lblError" styleClass="error-label" text=""/>
    </VBox>

    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
        <Button text="＋  Thêm vào giỏ" styleClass="btn btn-outline" onAction="#handleAddToCart"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="✕  Hủy" styleClass="btn btn-secondary" onAction="#handleCancel"/>
        <Button fx:id="btnXacNhan" text="✔  Xác nhận order" styleClass="btn btn-success"
                onAction="#handleXacNhan"/>
    </HBox>

</VBox>
