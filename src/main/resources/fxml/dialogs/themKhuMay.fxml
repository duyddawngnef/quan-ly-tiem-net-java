<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialog.ThemKhuMayDialog"
      stylesheets="@../../css/style.css"
      spacing="0" style="-fx-min-width:460; -fx-max-width:520;">

    <!-- Header -->
    <HBox styleClass="dialog-header" spacing="12" alignment="CENTER_LEFT">
        <Label text="💻" style="-fx-font-size:22px;"/>
        <Label fx:id="lblDialogTitle" text="Thêm / Sửa Khu Máy" styleClass="dialog-title"/>
    </HBox>

    <!-- Body -->
    <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-max-height:480;">
        <VBox styleClass="dialog-body" spacing="12">
            <VBox spacing="4">
                <Label text="Mã khu *" styleClass="form-label"/>
                <TextField fx:id="txtMaKhu" promptText="VD: KHU001" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtMaKhuError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tên khu *" styleClass="form-label"/>
                <TextField fx:id="txtTenKhu" promptText="VD: Khu Thường" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtTenKhuError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Giá cơ sở (VNĐ) *" styleClass="form-label"/>
                <TextField fx:id="txtGiaCoso" promptText="VD: 10000" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtGiaCosoError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Số máy *" styleClass="form-label"/>
                <TextField fx:id="txtSoMayToiDa" promptText="VD: 5" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtSoMayToiDaError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Trạng thái" styleClass="form-label"/>
                <ComboBox fx:id="cboTrangThai" promptText="Chọn trạng thái" styleClass="combo-box" maxWidth="Infinity"/>
                <Label fx:id="lblcboTrangThaiError" styleClass="error-label" text=""/>
            </VBox>

            <Label fx:id="lblError" styleClass="error-label" text="" wrapText="true"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
        <Button text="✕  Hủy" styleClass="btn btn-secondary"
                onAction="#handleCancel"/>
        <Button fx:id="btnSave" text="💾  Lưu" styleClass="btn btn-primary"
                onAction="#handleSave"/>
    </HBox>

</VBox>
